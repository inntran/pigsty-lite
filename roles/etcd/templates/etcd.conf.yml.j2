# {{ ansible_managed }}
# Rendered by roles/etcd. Do not edit by hand.

name: {{ etcd_member_name }}
data-dir: {{ etcd_data_dir }}

# Client / peer URLs
listen-client-urls: https://{{ etcd_listen_url_host }}:{{ etcd_client_port }}
advertise-client-urls: https://{{ etcd_advertise_url_host }}:{{ etcd_client_port }}
listen-peer-urls: https://{{ etcd_listen_url_host }}:{{ etcd_peer_port }}
initial-advertise-peer-urls: https://{{ etcd_advertise_url_host }}:{{ etcd_peer_port }}

# Cluster bootstrap
initial-cluster-token: {{ etcd_cluster_token }}
initial-cluster: {% for h in groups['etcd'] %}{% if hostvars[h].etcd_advertise_address is defined %}{% set peer_host = hostvars[h].etcd_advertise_address %}{% elif hostvars[h].ansible_host is defined %}{% set peer_host = hostvars[h].ansible_host %}{% else %}{% set peer_host = hostvars[h].ansible_default_ipv4.address %}{% endif %}{{ h }}=https://{{ '[' ~ peer_host ~ ']' if ':' in (peer_host | string) and not (peer_host | string).startswith('[') else peer_host }}:{{ etcd_peer_port }}{% if not loop.last %},{% endif %}{% endfor %}

initial-cluster-state: {{ etcd_initial_cluster_state }}

# TLS - client endpoint
client-transport-security:
  cert-file: {{ etcd_cert_file }}
  key-file: {{ etcd_key_file }}
  trusted-ca-file: {{ etcd_trusted_ca_file }}
  client-cert-auth: true

# TLS - peer endpoint
peer-transport-security:
  cert-file: {{ etcd_cert_file }}
  key-file: {{ etcd_key_file }}
  trusted-ca-file: {{ etcd_trusted_ca_file }}
  client-cert-auth: true

# Logging
logger: zap
log-outputs:
  - stderr

# Operational tuning (defaults; can be overridden via etcd_*)
heartbeat-interval: 250
election-timeout: 1500
auto-compaction-mode: periodic
auto-compaction-retention: "1h"
