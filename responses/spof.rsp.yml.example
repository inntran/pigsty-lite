# pigsty-lite response file - SPOF profile (1 monitor + 1 postgres).
# Copy to responses/site.rsp.yml and edit IPv4/IPv6 IPs / credentials / domain.
# Then run: ./configure -s -f responses/site.rsp.yml
---
profile: spof
network:
  ip_version: dual  # dual, ipv4, or ipv6
cluster:
  name: pg-dev
  domain: example.internal
nodes:
  pgmon01:
    ip: 10.20.30.10
    role: monitor
  pgnode01:
    ip: 10.20.30.11
    role: pg_primary
postgres:
  version: 18
  port: 5432
  tune: oltp
  shared_buffer_ratio: 0.25
  # P3 day-2 workflow: edit these declarative lists, then run make deploy.
  extensions: [pg_stat_statements]
  databases: []
  users: []
  hba_rules: []
  # Minor-upgrade safety: make minor-upgrade refuses unless a backup
  # exists within this window. Optional; defaults to 24 hours.
  # minor_upgrade:
  #   require_recent_backup_hours: 24
  # Pin a specific minor version (otherwise dnf takes the latest):
  # pin_version: "18.4"
# P4 day-2 workflow: edit this block, then run make deploy. See
# docs/operations/day2-backups.md.
backup:
  enabled: false
tls:
  internal_ca: generate
  user_facing: {mode: ca_signed}
# P5 day-2 workflow: edit this block, then run make deploy. See
# docs/operations/day2-monitoring.md.
monitoring:
  vmsingle_retention: 30d
  vlsingle_retention: 14d
  alertmanager: {receivers: []}
repos:
  pigsty: {enabled: false, packages: []}
firewall:
  operator_cidrs: ["10.0.0.0/8"]
  postgres_client_cidrs: ["10.20.40.0/24"]

# Optional. Defaults: rto_profile=norm, backend_target=pgbouncer, vip-manager disabled.
# connection_layer:
#   haproxy:
#     rto_profile: norm        # tight | norm | loose
#     backend_target: pgbouncer  # pgbouncer | postgres
#   vip_manager:
#     enabled: false
#     vip_cidr: "10.20.30.20/24"
#     interface: "eth0"
